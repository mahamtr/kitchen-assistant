# Optional frontend override.
# Leave EXPO_PUBLIC_BACKEND_URL unset to use platform defaults:
# - Web / iOS simulator: http://localhost:3000
# - Android emulator: http://10.0.2.2:3000
# For a physical device, set your host LAN IP explicitly, for example:
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.42:3000
